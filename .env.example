# ═══════════════════════════════════════════════════════════
# DHYEY PORTFOLIO — ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub.

# ── DATABASE ──────────────────────────────────────────────
# Render:  Settings → Environment → Add DB → copy the "External Database URL"
# Railway: Variables → DATABASE_URL is auto-injected when you add PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── NODE ENV ──────────────────────────────────────────────
# Set to "production" when deployed; "development" for local
NODE_ENV=production

# ── EMAIL ─────────────────────────────────────────────────
# Use your Gmail address
EMAIL_USER=your-gmail@gmail.com

# IMPORTANT: Use a Gmail App Password, NOT your real Gmail password.
# How to get one:
#   1. Go to myaccount.google.com/security
#   2. Enable 2-Step Verification
#   3. Go to App Passwords → create one for "Mail"
#   4. Paste the 16-char code below (no spaces)
EMAIL_PASS=your-16-char-app-password

# Email address to receive notifications (can be same as EMAIL_USER)
NOTIFY_EMAIL=ucxolives@gmail.com

# ── ANALYTICS ─────────────────────────────────────────────
# Password to access yoursite.com/analytics?password=THIS_VALUE
# Change this to something strong!
ANALYTICS_PASSWORD=dhyey@analytics2025

# ── SERVER ────────────────────────────────────────────────
# Render and Railway auto-set PORT — leave blank for production
PORT=3000
